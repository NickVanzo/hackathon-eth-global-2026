# =============================================================================
# Agent Arena — Environment Variables
# Copy this file to .env and fill in all values. NEVER commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Wallets
# All private keys must be hex strings WITHOUT a leading 0x prefix.
# -----------------------------------------------------------------------------

# Deployer wallet — used to deploy all contracts on both chains
PRIVATE_KEY_DEPLOYER=

# Relayer wallet — bridges events between 0G testnet and Sepolia
PRIVATE_KEY_RELAYER=

# Agent wallets — autonomous LP strategy agents registered in AgentManager
PRIVATE_KEY_AGENT_A=
PRIVATE_KEY_AGENT_B=
PRIVATE_KEY_AGENT_C=

# -----------------------------------------------------------------------------
# 0G Testnet (Galileo) — hosts Vault, AgentManager, iNFT contracts
# Source: https://docs.0g.ai/run-a-node/testnet-information
# -----------------------------------------------------------------------------

# Public EVM-compatible RPC for 0G Galileo testnet
OG_RPC_URL=https://evmrpc-testnet.0g.ai

# 0G Galileo chain ID
OG_CHAIN_ID=16602

# Block explorer for 0G Galileo
OG_EXPLORER_URL=https://chainscan-galileo.0g.ai

# 0G Storage RPC endpoint (used by SDK for uploads/downloads)
OG_STORAGE_RPC=https://storagerpc-testnet.0g.ai

# 0G Storage indexer (turbo) — used by Indexer client
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# -----------------------------------------------------------------------------
# Sepolia — hosts Satellite contract + Uniswap v3 pool (USDC.e/WETH)
# -----------------------------------------------------------------------------

# Alchemy or Infura Sepolia HTTP endpoint
SEPOLIA_RPC_URL=

# Sepolia chain ID (Ethereum testnet)
SEPOLIA_CHAIN_ID=11155111

# Etherscan API key for contract verification on Sepolia
ETHERSCAN_API_KEY=

# -----------------------------------------------------------------------------
# Contract Addresses — filled automatically at deploy time
# -----------------------------------------------------------------------------

# 0G testnet contracts
VAULT_ADDRESS=
AGENT_MANAGER_ADDRESS=
INFT_ADDRESS=

# Sepolia contracts
SATELLITE_ADDRESS=

# -----------------------------------------------------------------------------
# Uniswap v3 Pool Configuration (Sepolia)
# USDC.e/WETH pool used for LP strategy execution
# -----------------------------------------------------------------------------

# Sepolia — Uniswap v3 + tokens
SEPOLIA_RPC_URL=                    # filled by PM setup

# USDC.e token address on Sepolia (bridged USDC)
USDC_E_ADDRESS=                     # filled by PM setup

# WETH token address on Sepolia
WETH_ADDRESS=                       # filled by PM setup

# Deployed USDC.e/WETH Uniswap v3 pool address on Sepolia
UNISWAP_V3_POOL_ADDRESS=            # filled by PM setup

# Pool fee tier in hundredths of a bip (3000 = 0.30%)
UNISWAP_POOL_FEE=3000

# Uniswap v3 NonfungiblePositionManager address on Sepolia
UNISWAP_POSITION_MANAGER=           # filled by PM setup

# Uniswap v3 SwapRouter address on Sepolia
UNISWAP_SWAP_ROUTER=                # filled by PM setup

# -----------------------------------------------------------------------------
# MCP Server — serves Uniswap subgraph data to agents
# -----------------------------------------------------------------------------

# Port the MCP server listens on (default: 3001)
MCP_SERVER_PORT=3001

# Full URL agents use to query the MCP server (e.g. http://localhost:3001)
MCP_SERVER_URL=

# -----------------------------------------------------------------------------
# TheGraph / Uniswap Subgraph
# -----------------------------------------------------------------------------

# API key from https://thegraph.com/studio/apikeys/
THEGRAPH_API_KEY=

# Full Uniswap v3 subgraph query URL (Sepolia)
# e.g. https://gateway.thegraph.com/api/<key>/subgraphs/id/<id>
UNISWAP_SUBGRAPH_URL=

# -----------------------------------------------------------------------------
# Protocol Epoch & Fee Configuration
# All rate values are in basis points (bps): 10000 = 100%
# -----------------------------------------------------------------------------

# Epoch length in seconds (300 = 5-minute demo epochs)
EPOCH_LENGTH=300

# Maximum fraction of vault TVL a single agent may deploy (8000 = 80%)
MAX_EXPOSURE_RATIO=8000

# Protocol fee charged on epoch yield before distribution (500 = 5%)
PROTOCOL_FEE_RATE=500

# Agent commission on profits earned for vault depositors (1000 = 10%)
COMMISSION_RATE=1000
