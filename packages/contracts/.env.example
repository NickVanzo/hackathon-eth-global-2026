# -----------------------------------------------------------------------------
# Wallet / Signer
# -----------------------------------------------------------------------------
# Deployer private key (0x-prefixed). Use a dedicated test key only.
PRIVATE_KEY_DEPLOYER=

# -----------------------------------------------------------------------------
# RPC / Verification
# -----------------------------------------------------------------------------
# Needed by foundry.toml rpc_endpoints.sepolia
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# Needed when using --verify on Sepolia
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# -----------------------------------------------------------------------------
# Core Addresses
# -----------------------------------------------------------------------------
# EOA authorized as relayer/messenger
ADDRESS_RELAYER=0x0000000000000000000000000000000000000000

# Protocol treasury/deployer EOA
ADDRESS_DEPLOYER=0x0000000000000000000000000000000000000000

# Deployed on Sepolia first, then reused by 0G deployment
SATELLITE_ADDRESS=0xeFD9583eF616e9770ca98E4201e940315128C0BF

# 0G contract addresses (filled after deployment)
# Placeholder for AgentManager until it is deployed
AGENT_MANAGER_ADDRESS=0x9F36F2581A4f5773cE1B7E25Bc2F83b1b3cFAC06
VAULT_ADDRESS=0x5192fD3147D8e1a2392c8cBe7E33B8ec46e07628
INFT_ADDRESS=
# -----------------------------------------------------------------------------
# Market / Token Addresses
# -----------------------------------------------------------------------------
UNISWAP_V3_POOL_ADDRESS=0x0000000000000000000000000000000000000000
USDC_E_ADDRESS=0x0000000000000000000000000000000000000000
UNISWAP_POSITION_MANAGER=0x0000000000000000000000000000000000000000
UNISWAP_SWAP_ROUTER=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# Vault Parameters (0G deployment)
# -----------------------------------------------------------------------------
# Example: 3600 for hourly epochs (or blocks-based if your contract expects blocks)
EPOCH_LENGTH=3600

# Basis points style examples; adjust to your contract expectations
MAX_EXPOSURE_RATIO=8000
PROTOCOL_FEE_RATE=300
COMMISSION_RATE=1000


