# ---------------------------------------------------------------------------
# Envio indexer token
# Get yours at https://envio.dev/app/api-tokens
# ---------------------------------------------------------------------------
ENVIO_API_TOKEN="<YOUR-ENVIO-API-TOKEN>"

# ---------------------------------------------------------------------------
# Relayer signer — used to send cross-chain relay transactions
# Must match the `messenger` address set on all three contracts
# ---------------------------------------------------------------------------
PRIVATE_KEY_RELAYER="<0x...RELAYER_PRIVATE_KEY>"

# ---------------------------------------------------------------------------
# RPC URLs
# ---------------------------------------------------------------------------
SEPOLIA_RPC_URL="https://ethereum-sepolia.publicnode.com"
ZG_RPC_URL="https://evmrpc-testnet.0g.ai"

# ---------------------------------------------------------------------------
# Contract addresses
# ---------------------------------------------------------------------------
SATELLITE_ADDRESS="0x2346beaf07eed640166a2a921e9b650cbad0530b"
VAULT_ADDRESS="0x0c7704a97cc88f9e068c1f7a99881666f1db675a"
AGENT_MANAGER_ADDRESS="0x2346beaf07eed640166a2a921e9b650cbad0530b"

# ---------------------------------------------------------------------------
# Token addresses (Sepolia)
# ---------------------------------------------------------------------------
USDC_E_ADDRESS="0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238"
WETH_ADDRESS="0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14"

# ---------------------------------------------------------------------------
# Uniswap Trading API
# Get your key at https://developers.uniswap.org/
# Base URL: https://trade-api.gateway.uniswap.org/v1
# Sepolia (11155111) is a supported chain.
#
# Endpoints used by the relayer:
#   POST /check_approval  — check if satellite has approved tokens for the Universal Router
#   POST /quote           — get an executable quote with optimized routing (force CLASSIC)
#   POST /swap            — get signed Universal Router calldata from the quote
#
# Used for building swap calldata (zap-in / zap-out) for IntentQueued and forceClose.
# Without it, swap calldata falls back to "0x" (satellite handles deposit-token-only recovery).
# ---------------------------------------------------------------------------
UNISWAP_API_KEY="<YOUR-UNISWAP-API-KEY>"
