{
  "name": "subgraph-mcp-functions",
  "version": "1.0.0",
  "description": "MCP server exposing Uniswap V3 subgraph tools via Firebase Cloud Functions",
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^5.1.1",
    "ethers": "^6.13.0",
    "dotenv": "^16.4.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.37",
    "typescript": "^5.9.3"
  }
}
